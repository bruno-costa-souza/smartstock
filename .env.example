# ──────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores
# NUNCA comite o arquivo .env no repositório
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartstock

# ─── JWT ──────────────────────────────────────────────────────
# Em produção: gere com `openssl rand -base64 48`
# Mínimo 32 caracteres. Valores abaixo são APENAS para desenvolvimento local.
JWT_SECRET=dev_jwt_secret_change_in_production_32chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production_32chars

# ─── App ──────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# ─── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
